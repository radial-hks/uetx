Begin Object Class=/Script/UnrealEd.MaterialGraphNode Name="MaterialGraphNode_0"
   Begin Object Class=/Script/Engine.MaterialExpressionCustom Name="MaterialExpressionCustom_33CC8D43"
   End Object
   Begin Object Name="MaterialExpressionCustom_33CC8D43"
      Code="/* =================================================================================\r\n * [Unreal Material Custom Node Template]\r\n * ---------------------------------------------------------------------------------\r\n * 1. CONFIGURATION (节点属性设置)\r\n * - Description (描述): 基于世界空间Z轴高度区分水上和水下状态，并分别赋予自定义颜色（包含透明度）。输出包含Alpha的四维颜色值。\r\n * - Output Type (输出类型): [CMOT Float 4]\r\n *\r\n * 2. INPUTS (需要在 Custom 节点上添加的引脚)\r\n * 注意：引脚名称必须与下方代码中的变量名完全一致\r\n * ------------------------------------------------------------------------------\r\n * Pin 0 Name: [WorldPosition]    | Type suggestion: Vector 3 (推荐连接: Absolute World Position)\r\n * Pin 1 Name: [WaterLevel]       | Type suggestion: Scalar (推荐: 暴露为材质参数)\r\n * Pin 2 Name: [Feather]          | Type suggestion: Scalar (推荐: 暴露为材质参数，例如 10.0)\r\n * Pin 3 Name: [AboveWaterColor]  | Type suggestion: Vector 3 (水上基础颜色 RGB)\r\n * Pin 4 Name: [AboveWaterAlpha]  | Type suggestion: Scalar   (水上透明度 Alpha)\r\n * Pin 5 Name: [UnderwaterColor]  | Type suggestion: Vector 3 (水下基础颜色 RGB)\r\n * Pin 6 Name: [UnderwaterAlpha]  | Type suggestion: Scalar   (水下透明度 Alpha)\r\n * =================================================================================\r\n */\r\n\r\n// --- [CODE BODY START] ---\r\n\r\n// 1. 将输入的 RGB 和 Alpha 组装成安全的 float4 颜色\r\n// 这可以彻底避免 float3 无法隐式转换为 float4 的报错\r\nfloat4 colorAbove = float4(AboveWaterColor, AboveWaterAlpha);\r\nfloat4 colorUnder = float4(UnderwaterColor, UnderwaterAlpha);\r\n\r\n// 2. 安全处理：防止羽化值为0导致除以0的报错\r\nfloat safeFeather = max(Feather, 0.0001);\r\n\r\n// 3. 计算高度差 (水面高度 - 像素当前世界高度)\r\n// 当像素位于水下时 (WorldPosition.z < WaterLevel)，depthDiff 为正数\r\n// 当像素位于水上时 (WorldPosition.z > WaterLevel)，depthDiff 为负数\r\nfloat depthDiff = WaterLevel - WorldPosition.z;\r\n\r\n// 4. 计算浸没遮罩并限制在 0~1 之间\r\nfloat mask = saturate(depthDiff / safeFeather);\r\n\r\n// 5. 根据遮罩混合水上和水下颜色 (包括 Alpha 通道)\r\nfloat4 finalColor = lerp(colorAbove, colorUnder, mask);\r\n\r\n// Return\r\nreturn finalColor;\r\n\r\n// --- [CODE BODY END] ---"
      OutputType=CMOT_Float4
      Inputs(0)=(InputName="WorldPosition",Input=(Expression=MaterialExpressionWorldPosition'"MaterialGraphNode_2.MaterialExpressionWorldPosition_0"'))
      Inputs(1)=(InputName="WaterLevel",Input=(Expression=MaterialExpressionScalarParameter'"MaterialGraphNode_3.MaterialExpressionScalarParameter_2A4EF6B9"'))
      Inputs(2)=(InputName="Feather",Input=(Expression=MaterialExpressionScalarParameter'"MaterialGraphNode_4.MaterialExpressionScalarParameter_98CF1C41"'))
      Inputs(3)=(InputName="AboveWaterColor",Input=(Expression=MaterialExpressionVectorParameter'"MaterialGraphNode_5.MaterialExpressionVectorParameter_A19DA163"',Mask=1,MaskR=1,MaskG=1,MaskB=1))
      Inputs(4)=(InputName="AboveWaterAlpha",Input=(Expression=MaterialExpressionScalarParameter'"MaterialGraphNode_6.MaterialExpressionScalarParameter_DED4F7E5"'))
      Inputs(5)=(InputName="UnderwaterColor",Input=(Expression=MaterialExpressionVectorParameter'"MaterialGraphNode_7.MaterialExpressionVectorParameter_16E28F7C"',Mask=1,MaskR=1,MaskG=1,MaskB=1))
      Inputs(6)=(InputName="UnderwaterAlpha",Input=(Expression=MaterialExpressionScalarParameter'"MaterialGraphNode_8.MaterialExpressionScalarParameter_96EF5141"'))
      MaterialExpressionEditorX=-432
      MaterialExpressionEditorY=528
      MaterialExpressionGuid=D00E5733320300E2D5AFBE441E77F6D7
      Material=PreviewMaterial'"/Engine/Transient.M_WaterLevel"'
   End Object
   MaterialExpression=MaterialExpressionCustom'"MaterialExpressionCustom_33CC8D43"'
   NodePosX=-432
   NodePosY=528
   NodeGuid=544C803A48B38EB7678718A28DF5C01B
